# StarAgent Proxy v2.0 Configuration (legacy compatible: MacAgent)

# ==============================================================================
# Ollama Configuration
# ==============================================================================
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_PATH=/api/chat
DEFAULT_MODEL=gemma4:e2b

# ==============================================================================
# Storage Configuration
# ==============================================================================
# Memory files and legacy JSON storage
MEMORY_DIR=./data/memory
# SQLite database path
DATABASE_PATH=./data/memory.db
# Migrate from JSON to SQLite on startup
MIGRATE_FROM_JSON=true

# ==============================================================================
# Memory Management
# ==============================================================================
# Maximum historical turns to archive per conversation
MAX_ARCHIVE_TURNS=200
# Maximum memory items to retrieve per query
MAX_RETRIEVED_ITEMS=6
# Update memory after each response
ENABLE_MEMORY_UPDATE=true
# Memory compaction trigger (every N turns)
COMPACTION_INTERVAL=100

# ==============================================================================
# Feature Flags
# ==============================================================================
# Enable semantic search via embeddings (requires sentence-transformers)
USE_SEMANTIC_SEARCH=true
# Enable SSE streaming responses
USE_STREAMING=true

# ==============================================================================
# API Security
# ==============================================================================
# Bearer token for Authorization header validation
# Set empty string to disable authentication
PROXY_API_KEY=local-dev-key

# ==============================================================================
# Token Budgeting (per conversation, 24-hour reset)
# ==============================================================================
# Maximum prompt tokens per conversation (system + context + recent messages)
DEFAULT_PROMPT_TOKENS=2000
# Maximum completion tokens per conversation (model response)
DEFAULT_COMPLETION_TOKENS=2000

# ==============================================================================
# Logging & Monitoring
# ==============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==============================================================================
# Server Bindings (used by scripts; app is started via uvicorn)
# ==============================================================================
# Bind interface for uvicorn (0.0.0.0 is recommended for Open WebUI in Docker).
HOST=0.0.0.0
# Default port for recovered runtime
PORT=8095

# ==============================================================================
# API Identity Branding (safe toggle)
# ==============================================================================
# When enabled, StarAgent will present StarAgent identity strings in /health and /v1/models.
# Shapes are unchanged; only branding strings are toggled.
# Default: false (legacy MacAgent identity strings)
STARAGENT_BRAND_API=false

# ==============================================================================
# CLI / MCP Client Defaults
# ==============================================================================
# OpenAI-compatible base URL for StarAgent clients (note the /v1 suffix)
STARAGENT_BASE_URL=http://127.0.0.1:8095/v1
# API key for StarAgent clients
STARAGENT_API_KEY=local-dev-key
# Default model used by CLI/MCP clients
STARAGENT_DEFAULT_MODEL=gemma4:e2b
# Default project scope
STARAGENT_DEFAULT_PROJECT=default
# Conversation id prefix used by CLI when one is not provided
STARAGENT_DEFAULT_CONVERSATION_PREFIX=cli

# Legacy compatibility (optional):
# MACAGENT_BASE_URL=http://127.0.0.1:8095/v1
# MACAGENT_API_KEY=local-dev-key
# MACAGENT_DEFAULT_MODEL=gemma4:e2b
# MACAGENT_DEFAULT_PROJECT=default
# MACAGENT_DEFAULT_CONVERSATION_PREFIX=cli
